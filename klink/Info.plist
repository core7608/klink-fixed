	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- English is the app's language; layout follows the system default
	     (left-to-right). -->
	<key>CFBundleAllowMixedLocalizations</key>
	<true/>

	<!-- Media / security permission strings — required for camera, photo
	     library, microphone (voice messages), and Face ID (app lock). -->
	<key>NSCameraUsageDescription</key>
	<string>klink uses the camera to capture photos and videos to send in chats.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>klink needs access to your photo library to send photos and videos in chats.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>klink needs permission to save media you receive to your photo library.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>klink uses the microphone to record voice messages and calls.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>klink uses Face ID to lock the app and protect your conversations.</string>
	<key>NSContactsUsageDescription</key>
	<string>klink uses your contacts to help you find friends who are already on the app.</string>

	<!-- Networking: only Firebase/Google endpoints over HTTPS are contacted,
	     so no ATS exceptions are needed. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
</dict>
</plist>
